# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
LOG_FORMAT=dev
CREDENTIALS=true

# Client URLs
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# Base API URL (used for building absolute links to API resources)
API_BASE_URL=http://localhost:5000/api/v1

# Database
MONGODB_URI=mongodb://localhost:27017/mentwel

# Redis (optional, for rate limiting)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET= 826775364b0bb011bc4669a0b503f32517cab8d2dbcb0fe1cf350e2524698d26848af72d6901eae9e59fcc8551064578f8c517edd352dfc5f3aff6e1a618f54a
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Email Configuration
# For Gmail: smtp.gmail.com, port 587, secure=false (use App Password, not regular password)
# For SendGrid: smtp.sendgrid.net, port 587, secure=false (use API key as password)
# For AWS SES: email-smtp.us-east-1.amazonaws.com, port 587, secure=false
# For Mailgun: smtp.mailgun.org, port 587, secure=false
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=MentWel <noreply@mentwel.com>

# Email Verification
# Set to 'false' to allow login without email verification (useful during development)
REQUIRE_EMAIL_VERIFICATION=false

